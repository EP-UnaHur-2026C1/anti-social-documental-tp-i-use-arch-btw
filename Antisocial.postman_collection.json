{
    "info": {
        "name": "Antisocial API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "0 - Setup inicial (users + tags)",
            "item": [
                {
                    "name": "Crear usuarios",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const users = JSON.parse(pm.request.body.raw);",
                                    "const results = [];",
                                    "const baseUrl = pm.collectionVariables.get('baseUrl');",
                                    "const requests = users.map(user =>",
                                    "    new Promise(resolve => {",
                                    "        pm.sendRequest({",
                                    "            url: baseUrl + '/api/users',",
                                    "            method: 'POST',",
                                    "            header: { 'Content-Type': 'application/json' },",
                                    "            body: { mode: 'raw', raw: JSON.stringify(user) }",
                                    "        }, (err, res) => {",
                                    "            results.push({ user: user.nickName, status: res.code });",
                                    "            resolve();",
                                    "        });",
                                    "    })",
                                    ");",
                                    "Promise.all(requests).then(() => {",
                                    "    pm.response.setBody({ created: results });",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "[{\"nickName\":\"lean\",\"email\":\"lean@gmail.com\",\"name\":\"Leandro\",\"surname\":\"Fernández\"},{\"nickName\":\"gabriel\",\"email\":\"gab@gmail.com\",\"name\":\"Gabriel\",\"surname\":\"Herrera\"},{\"nickName\":\"Luna\",\"email\":\"luna@gmail.com\",\"name\":\"Luna\",\"surname\":\"Moon\"},{\"nickName\":\"juan\",\"email\":\"juan@gmail.com\",\"name\":\"Juan\",\"surname\":\"Pérez\"},{\"nickName\":\"maria\",\"email\":\"maria@gmail.com\",\"name\":\"María\",\"surname\":\"García\"}]"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/users",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "users"]
                        }
                    }
                },
                {
                    "name": "Crear tags",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const tags = ['programming', 'travel', 'food', 'music', 'fitness'];",
                                    "const baseUrl = pm.collectionVariables.get('baseUrl');",
                                    "const requests = tags.map(name =>",
                                    "    new Promise(resolve => {",
                                    "        pm.sendRequest({",
                                    "            url: baseUrl + '/api/tags',",
                                    "            method: 'POST',",
                                    "            header: { 'Content-Type': 'application/json' },",
                                    "            body: { mode: 'raw', raw: JSON.stringify({ name }) }",
                                    "        }, (err, res) => {",
                                    "            try {",
                                    "                const data = typeof res.json().data === 'object' ? res.json().data : res.json();",
                                    "                pm.collectionVariables.set('tag_' + name, data._id);",
                                    "            } catch(e) {}",
                                    "            resolve();",
                                    "        });",
                                    "    })",
                                    ");",
                                    "Promise.all(requests).then(() => {",
                                    "    pm.response.setBody({ message: 'Tags creados' });",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"name\":\"dummy\"}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/tags",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "tags"]
                        }
                    }
                },
                {
                    "name": "Obtener todos los usuarios",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/users",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "users"]
                        }
                    }
                },
                {
                    "name": "Obtener todos los tags",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/tags",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "tags"]
                        }
                    }
                }
            ]
        },
