        {
            "name": "3 - Comments",
            "item": [
                {
                    "name": "Crear comentarios",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const baseUrl = pm.collectionVariables.get('baseUrl');",
                                    "const p1 = pm.collectionVariables.get('postId1');",
                                    "const p2 = pm.collectionVariables.get('postId2');",
                                    "const p3 = pm.collectionVariables.get('postId3');",
                                    "const p4 = pm.collectionVariables.get('postId4');",
                                    "const comments = [",
                                    "  { user_nickName: 'Luna', post_id: p1, content: 'Qué bien se ve ese código!' },",
                                    "  { user_nickName: 'gabriel', post_id: p1, content: 'Compartí el repo!' },",
                                    "  { user_nickName: 'lean', post_id: p2, content: 'Hermosa playa! 🌊' },",
                                    "  { user_nickName: 'juan', post_id: p2, content: 'Dónde es eso?' },",
                                    "  { user_nickName: 'Luna', post_id: p3, content: 'Pasá la receta!' },",
                                    "  { user_nickName: 'lean', post_id: p3, content: 'Se ve delicioso 🤤' },",
                                    "  { user_nickName: 'maria', post_id: p4, content: 'Pasá el link!' }",
                                    "];",
                                    "const results = [];",
                                    "const requests = comments.map(c =>",
                                    "    new Promise(resolve => {",
                                    "        pm.sendRequest({",
                                    "            url: baseUrl + '/api/comments',",
                                    "            method: 'POST',",
                                    "            header: { 'Content-Type': 'application/json' },",
                                    "            body: { mode: 'raw', raw: JSON.stringify(c) }",
                                    "        }, (err, res) => {",
                                    "            results.push({ content: c.content, status: res.code });",
                                    "            resolve();",
                                    "        });",
                                    "    })",
                                    ");",
                                    "Promise.all(requests).then(() => {",
                                    "    pm.response.setBody({ created: results });",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"user_nickName\":\"lean\",\"post_id\":\"{{postId1}}\",\"content\":\"test\"}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/comments",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "comments"]
                        }
